# Clerk — create a NEW application at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex — run `npx convex dev` in this folder to generate these
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Set these in the Convex Dashboard (Settings → Environment Variables), not .env.local:
# CLERK_JWT_ISSUER_DOMAIN — Clerk JWT template "convex" → Issuer URL
# CLERK_WEBHOOK_SECRET — Clerk Webhooks → your endpoint → Signing secret
# CLERK_SECRET_KEY — Clerk API → Secret key (same as .env.local; needed for account deletion)
# OWNER_EMAIL — email of the workspace Owner (super super admin); e.g. you@company.com
# PUBLICITY_VIEWER_EMAILS — comma-separated emails allowed to view publicity files (Owner always included)
